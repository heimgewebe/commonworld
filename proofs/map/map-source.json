{
  "schema_version": 1,
  "mode": "proof",
  "name": "commonworld static map proof source",
  "library": {
    "name": "maplibre-gl",
    "version": "3.6.2",
    "script_url": "https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js",
    "css_url": "https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css"
  },
  "basemap": {
    "kind": "raster-style",
    "provider": "CARTO",
    "provider_terms_url": "https://carto.com/basemaps/",
    "cache_policy": "Proof-only browser and CDN cache; commonworld must not operate a tile cache here.",
    "style": {
      "version": 8,
      "sources": {
        "carto-dark-matter": {
          "type": "raster",
          "tiles": [
            "https://a.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}@2x.png"
          ],
          "tileSize": 256,
          "attribution": "© OpenStreetMap contributors © CARTO"
        }
      },
      "layers": [
        {
          "id": "carto-dark-matter-layer",
          "type": "raster",
          "source": "carto-dark-matter"
        }
      ]
    }
  },
  "initial_view": {
    "center": [
      10.4515,
      51.1657
    ],
    "zoom": 5
  },
  "disclosure": "This proof loads MapLibre from a CDN and raster map tiles from CARTO for proof-only basemap rendering.",
  "failure_mode_copy": "Map source dependencies did not load.",
  "privacy_notes": "Basemap choice must not change CommonProject location privacy projection."
}
