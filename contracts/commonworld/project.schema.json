{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commonworld.net/contracts/commonworld/project.schema.json",
  "title": "CommonProject",
  "description": "Public catalog contract for commonworld Commons atlas entries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "summary",
    "sphere",
    "aspects",
    "location",
    "projections",
    "provenance",
    "curation",
    "links"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,95}$"
    },
    "title": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500
    },
    "sphere": {
      "type": "string",
      "enum": [
        "place",
        "digital",
        "hybrid"
      ]
    },
    "aspects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "$ref": "https://commonworld.net/contracts/commonworld/aspect.schema.json"
      }
    },
    "location": {
      "$ref": "#/$defs/location"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "curation": {
      "$ref": "#/$defs/curation"
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "handoff": {
      "$ref": "#/$defs/handoff"
    },
    "projections": {
      "$ref": "#/$defs/projections"
    }
  },
  "$defs": {
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "label",
        "precision"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "exact",
            "approximate",
            "hidden"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        },
        "precision": {
          "type": "string",
          "enum": [
            "exact",
            "city",
            "region",
            "country",
            "none"
          ]
        },
        "coordinates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "lat",
            "lon"
          ],
          "properties": {
            "lat": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            "lon": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            }
          }
        },
        "accuracy_meters_min": {
          "type": "integer",
          "minimum": 1,
          "description": "Lower bound for intentional location blur when mode is approximate."
        },
        "privacy_note": {
          "type": "string",
          "maxLength": 500
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "exact"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "required": [
              "coordinates"
            ],
            "properties": {
              "precision": {
                "const": "exact"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "approximate"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "precision": {
                "enum": [
                  "city",
                  "region",
                  "country"
                ]
              }
            },
            "not": {
              "properties": {
                "precision": {
                  "const": "exact"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "hidden"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "precision": {
                "const": "none"
              }
            },
            "not": {
              "required": [
                "coordinates"
              ]
            }
          }
        }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sources"
      ],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "summary": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "label"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "official-source",
            "public-registry",
            "manual-curation",
            "fixture",
            "derived"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date"
        },
        "note": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "curation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "fixture",
            "candidate",
            "curated",
            "archived"
          ]
        },
        "reviewed_by": {
          "type": "string",
          "maxLength": 120
        },
        "reviewed_at": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "label",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "homepage",
            "source",
            "license",
            "documentation",
            "map",
            "contact"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "system": {
          "type": "string",
          "enum": [
            "weltgewebe"
          ]
        },
        "project_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 160
        },
        "action_label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 160
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": [
              "enabled"
            ]
          },
          "then": {
            "required": [
              "system",
              "project_id",
              "action_label"
            ]
          }
        }
      ]
    },
    "projections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile"
      ],
      "properties": {
        "map": {
          "$ref": "#/$defs/map_projection"
        },
        "aether": {
          "$ref": "#/$defs/aether_projection"
        },
        "profile": {
          "$ref": "#/$defs/profile_projection"
        }
      },
      "anyOf": [
        {
          "required": [
            "map"
          ]
        },
        {
          "required": [
            "aether"
          ]
        }
      ]
    },
    "map_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appearance",
        "location_claim"
      ],
      "properties": {
        "appearance": {
          "type": "string",
          "enum": [
            "local-marker",
            "approximate-halo",
            "hybrid-code-pillar"
          ]
        },
        "location_claim": {
          "type": "string",
          "enum": [
            "exact",
            "approximate"
          ]
        },
        "note": {
          "type": "string",
          "maxLength": 300
        }
      }
    },
    "aether_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appearance",
        "stream",
        "ortssignal"
      ],
      "properties": {
        "appearance": {
          "type": "string",
          "enum": [
            "digital-card",
            "hidden-location-card",
            "hybrid-card"
          ]
        },
        "stream": {
          "type": "string",
          "enum": [
            "knowledge-data",
            "infrastructure",
            "education",
            "culture",
            "mutual-aid",
            "repair"
          ]
        },
        "ortssignal": {
          "type": "boolean"
        },
        "note": {
          "type": "string",
          "maxLength": 300
        }
      }
    },
    "profile_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "preserves_previous_projection"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "const": "focus-state"
        },
        "preserves_previous_projection": {
          "type": "boolean"
        },
        "handoff_state": {
          "type": "string",
          "enum": [
            "locked",
            "available"
          ]
        },
        "note": {
          "type": "string",
          "maxLength": 300
        }
      }
    }
  }
}
