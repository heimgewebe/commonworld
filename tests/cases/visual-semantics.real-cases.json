      "expected_composition": "making_infrastructure",
      "coverage_state": "partial",
      "expected_relation_policy": {
        "evidenced_connections": "eligible",
        "potential_nodes": "candidate_not_current_density",
        "speculative_connections": "exclude"
      },
      "expected_channels": {
        "hue": "making_infrastructure",
        "lightness": "none_for_partial_coverage",
