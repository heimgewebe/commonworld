{
  "schema_version": 1,
  "title": "Source-derived visual semantics research cases",
  "purpose": "Exercise Commonworld visual and privacy semantics against recognizable real-world Commons patterns without creating public catalog entries.",
  "visibility": {
    "repository_test_only_not_product_content": true,
    "public_repository_visibility_acknowledged": true,
    "excluded_from_public_shell": true,
    "not_catalog_truth": true,
    "not_publication_verification": true
  },
  "checked_at": "2026-07-11",
  "sources": {
    "wikimedia_projects": {
      "url": "https://wikimediafoundation.org/what-we-do/wikimedia-projects/",
      "source_kind": "official_project_operator",
      "evidence_summary": "Wikipedia is described as a free collaborative encyclopedia written in hundreds of languages by volunteers around the world."
    },
    "openstreetmap_about": {
      "url": "https://www.openstreetmap.org/about",
      "source_kind": "official_project_site",
      "evidence_summary": "OpenStreetMap describes globally contributed and maintained open map data built from local knowledge."
    },
    "repair_cafe_visit": {
      "url": "https://www.repaircafe.org/en/visit/",
      "source_kind": "official_network_directory",
      "evidence_summary": "The official visit surface presents local Repair Cafes as places that can be found and visited."
    },
    "foodsharing_map": {
      "url": "https://foodsharing.de/karte",
      "source_kind": "official_project_map",
      "evidence_summary": "The official map is the discovery surface for local foodsharing places such as Fairteiler."
    },
    "freifunk_community": {
      "url": "https://freifunk.net/wie-mache-ich-mit/community-finden/",
      "source_kind": "official_network_site",
      "evidence_summary": "Freifunk lists local communities, uses community metadata for a map and API, and invites participation through a router at home."
    },
    "nyc_mesh_map": {
      "url": "https://www.nycmesh.net/map",
      "source_kind": "official_network_map",
      "evidence_summary": "NYC Mesh distinguishes install locations, potential nodes and several connection types, including explicitly speculative connections."
    },
    "clt_brussels": {
      "url": "https://www.cltb.be/en/",
      "source_kind": "official_organization_site",
      "evidence_summary": "Community Land Trust Brussels presents multiple housing projects, shared gardens and community spaces under a common organization."
    }
  },
  "cases": [
    {
      "id": "wikipedia-global-knowledge",
      "source_refs": [
        "wikimedia_projects"
      ],
      "research_claim": "A globally available collaborative knowledge Commons has no meaningful single geographic coordinate.",
      "archetypes": [
        "digital_global_without_coordinate",
        "coverage_state_distinction"
      ],
      "project_pattern": "single_digital_identity_global_reach",
      "location_modes": [
        "not_applicable"
      ],
      "expected_composition": "knowledge_data",
      "coverage_state": "unassessed",
      "expected_channels": {
        "hue": "knowledge_data",
        "lightness": "none_without_comparable_assessed_density",
        "interior_texture": "open_dot_grid",
        "boundary_and_halo": "none"
      },
      "forbidden": [
        "invented_headquarters_marker",
        "geographic_density_denominator",
        "global_completeness_claim_without_defined_universe"
      ],
      "family_assignment": {
        "primary_family": "knowledge_data",
        "secondary_families": []
      }
    },
    {
      "id": "openstreetmap-distributed-open-data",
      "source_refs": [
        "openstreetmap_about"
